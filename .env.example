# IMPORTANT: if modifying this, also modify the .env.example if needed

# used by django
DATABASE_URL=psql://djangouser:defaultpassword@db:5432/transcendence
# used by the docker compose
# WARNING: must match DATABASE_URL
POSTGRES_USER=djangouser
POSTGRES_PASSWORD=defaultpassword
POSTGRES_DB=transcendence

# https://docs.docker.com/build/bake/
# faster docker build, require docker v2.20+
COMPOSE_BAKE=true

# Timezones
TZ=Europe/Paris